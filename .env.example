# Copy to .env.local and fill in.

# ── v1 backend (Google Apps Script + Sheets) ────────────────────────────────
VITE_RIPPLE_API_URL=https://script.google.com/macros/s/XXXX/exec
VITE_RIPPLE_TOKEN=your-long-random-secret-token

# ── Web push (both v1 and v2) ───────────────────────────────────────────────
VITE_VAPID_PUBLIC=your-vapid-public-key

# ── v2 backend (Supabase) — see docs/SUPABASE_V2.md ─────────────────────────
# From Supabase → Project Settings → API. The anon key is safe to embed.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
